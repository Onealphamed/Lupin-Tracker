# Copy to .env locally. Never commit .env.

# Google Sheet ID (the part of the URL between /d/ and /edit)
TRACKER_SHEET_ID=1iVYMDAIafpNMKieIJbLCiRplxeBokOGHe_knWQBhTJY

# Name of the main data tab. Leave as "Tracker" — the Apps Script falls
# back to the first sheet if this exact name isn't found, so it works
# even if the tab is called something else.
TRACKER_TAB=Tracker

# Apps Script Web App /exec URL (paste after deploying the script).
# REQUIRED for green-cell detection — without it the dashboard only shows
# a value-based estimate.
APPS_SCRIPT_URL=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Password for the dashboard login screen
DASHBOARD_PASSWORD=Alphamed@4321

# Must match the PASSWORD constant inside google_apps_script.js
TICK_PASSWORD=Alphamed@4321

# Any random 32+ char string. On Render this is auto-generated.
SECRET_KEY=change-me-to-a-random-string
