# Copy to .env locally. Never commit .env.

# Google Sheet ID (the part of the URL between /d/ and /edit)
TRACKER_SHEET_ID=1iVYMDAIafpNMKieIJbLCiRplxeBokOGHe_knWQBhTJY

# Name of the main data tab. Leave as "Tracker" — the Apps Script falls
# back to the first sheet if this exact name isn't found, so it works
# even if the tab is called something else.
TRACKER_TAB=Tracker

# Apps Script Web App /exec URL (paste after deploying the script).
# REQUIRED for green-cell detection — without it the dashboard only shows
# a value-based estimate.
APPS_SCRIPT_URL=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Password for the dashboard login screen
DASHBOARD_PASSWORD=CHANGE_ME

# Must match the PASSWORD constant inside google_apps_script.js
TICK_PASSWORD=CHANGE_ME

# Any random 32+ char string. On Render this is auto-generated.
SECRET_KEY=change-me-to-a-random-string

# Email (SMTP) — entirely optional. The real delivery path is the Apps
# Script MailApp fallback (uses the spreadsheet owner's Google account),
# because Render's free tier blocks outbound SMTP on port 587 anyway.
# Leave SMTP_USER + SMTP_PASSWORD blank to skip SMTP and rely on MailApp;
# fill them in for a paid Render plan or local dev with a Gmail App
# Password (https://myaccount.google.com/apppasswords — requires 2-Step
# Verification on the account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Lupin Tracker
SMTP_FROM_ADDR=

# Public URL of the dashboard, used as the CTA target inside email bodies.
DASHBOARD_PUBLIC_URL=https://lupin-tracker.onrender.com
